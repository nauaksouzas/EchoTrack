# Database (SQLite path is relative to the prisma/ directory)
DATABASE_URL="file:./dev.db"

# JWT signing secret (generate with: openssl rand -hex 32)
JWT_SECRET="REPLACE_WITH_RANDOM_HEX_64"

# Environment
NODE_ENV="development"

# Firebase admin (optional for production; uses public JWKS if absent)
# GOOGLE_APPLICATION_CREDENTIALS="server/firebase-service-account.json"
